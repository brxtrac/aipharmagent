{
  "@context": {
    "pharm": "https://aipharmagent.com/ontology#",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "name": "schema:name",
    "description": "schema:description",
    "title": "dcterms:title",
    "sourceDocument": { "@id": "pharm:sourceDocument", "@type": "@id" },
    "sourceExcerpt": { "@id": "pharm:sourceExcerpt", "@type": "@id" },
    "sourcePage": "pharm:sourcePage",
    "sourceSection": "pharm:sourceSection",
    "sourceQuote": "pharm:sourceQuote",
    "appliesToCondition": { "@id": "pharm:appliesToCondition", "@type": "@id" },
    "authorizedByAct": { "@id": "pharm:authorizedByAct", "@type": "@id" },
    "hasDoseAdjustmentRule": { "@id": "pharm:hasDoseAdjustmentRule", "@type": "@id" },
    "requiresMonitoring": "pharm:requiresMonitoring",
    "requiresFollowUp": "pharm:requiresFollowUp",
    "hasContraindication": "pharm:hasContraindication",
    "hasReferralCriterion": "pharm:hasReferralCriterion",
    "hasPatientCategory": "pharm:hasPatientCategory",
    "recommendation": "pharm:recommendation",
    "intervention": "pharm:intervention",
    "followUpInterval": "pharm:followUpInterval",
    "monitoringParameter": "pharm:monitoringParameter",
    "nonPharmacologicalMeasure": "pharm:nonPharmacologicalMeasure",
    "confidence": "pharm:confidence",
    "needsHumanReview": "pharm:needsHumanReview",
    "reviewStatus": "pharm:reviewStatus",
    "publishStatus": "pharm:publishStatus"
  }
}
