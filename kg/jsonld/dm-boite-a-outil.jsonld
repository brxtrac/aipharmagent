      "@id": "urn:pharmagent:dm-boite-a-outil:excerpt:026",
      "@type": "pharm:SourceExcerpt",
      "name": "DM-boite-a-outil - extrait 26",
      "description": "Référer le patient au programme des maladies chroniques ou lui conseiller de consulter un kinésiologue pour améliorer la maîtrise de la glycémie, faciliter la perte de poids et procurer d'autres bienfaits. ## Types d'activités",
      "sourceDocument": {
        "@id": "urn:pharmagent:dm-boite-a-outil:doc"
      },
      "sourcePage": "unknown",
      "sourceSection": "Types d'activités",
      "sourceQuote": "Référer le patient au programme des maladies chroniques ou lui conseiller de consulter un kinésiologue pour améliorer la maîtrise de la glycémie, faciliter la perte de poids et procurer d'autres bienfaits. ## Types d'activités",
      "needsHumanReview": true,
      "reviewStatus": "human_review",
      "publishStatus": "ready_for_working_memory"
    },
    {
      "@id": "urn:pharmagent:dm-boite-a-outil:excerpt:027",
